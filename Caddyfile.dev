# =============================================================
# 🔐 SNIPPETS
# =============================================================

(admin_auth) {
    basicauth {
        {$ADMIN_USER_NAME} {$ADMIN_PASSWORD_HASH}
    }
}

(api_routes) {
	handle /health {
		respond "ok" 200
	}

    handle_path /admin/beszel* {
        import admin_auth
        reverse_proxy beszel:8090
    }

	handle_path /identityx/* {
		reverse_proxy identity-x:8080
	}

	handle_path /informd/* {
		reverse_proxy informd:8080
	}

	handle_path /univents/* {
		reverse_proxy univents:8080
	}

	handle_path /payssage/* {
		reverse_proxy payssage:8080
	}
}

# =============================================================
# 🗄️ STORAGE (RustFS — host)
# =============================================================

:9000 {
	reverse_proxy rustfs:9000
}

:9001 {
	reverse_proxy rustfs:9001
}

# =============================================================
# 🌐 API GATEWAY
# =============================================================

:80 {
	import api_routes
}

# =============================================================
# 🔐 IDENTITY-X
# =============================================================

:8080 {
	reverse_proxy identity-x:8080
}

# =============================================================
# 🎟️ UNIVENTS
# =============================================================

:8081 {
	reverse_proxy univents:8080
}

# =============================================================
# 💳 PAYSSAGE
# =============================================================

:8082 {
	reverse_proxy payssage:8080
}

# =============================================================
# 📢 INFORMD
# =============================================================

:8083 {
	reverse_proxy informd:8080
}

:8090 {
    reverse_proxy beszel:8090
}
