# =============================================================
# 🔐 SNIPPETS
# =============================================================

(api_routes) {
	handle /health {
		respond "ok" 200
	}

	handle_path /identityx/* {
		reverse_proxy identityx:8080
	}

	handle_path /informd/* {
		reverse_proxy informd:8080
	}

	handle_path /univents/* {
		reverse_proxy univents:8080
	}

	handle_path /payssage/* {
		reverse_proxy payssage:8080
	}
}

# =============================================================
# 🌐 API GATEWAY
# =============================================================

:80 {
	import api_routes
}

# =============================================================
# 🔐 IDENTITY-X
# =============================================================

:8080 {
	reverse_proxy identityx:8080
}

# =============================================================
# 🎟️ UNIVENTS
# =============================================================

:8081 {
	reverse_proxy univents:8080
}

# =============================================================
# 💳 PAYSSAGE
# =============================================================

:8082 {
	reverse_proxy payssage:8080
}

# =============================================================
# 📢 INFORMD
# =============================================================

:8083 {
	reverse_proxy informd:8080
}

# =============================================================
# 📊 BESZEL (system monitoring)
# =============================================================

:8090 {
	reverse_proxy beszel:8090
}

# =============================================================
# 🗄️ RUSTFS (S3-compatible storage)
# =============================================================

:9000 {
	reverse_proxy rustfs:9000
}

:9001 {
	reverse_proxy rustfs:9001
}

# =============================================================
# 📊 GRAFANA
# =============================================================

:3000 {
	reverse_proxy grafana:3000
}

# =============================================================
# 📧 MAILPIT
# =============================================================

:8025 {
	reverse_proxy mailpit:8025
}

# =============================================================
# 📊 VICTORIA METRICS
# =============================================================

:8428 {
	reverse_proxy victoria-metrics:8428
}

# =============================================================
# 📝 VICTORIA LOGS
# =============================================================

:9428 {
	reverse_proxy victoria-logs:9428
}

# =============================================================
# 🔍 VICTORIA TRACES
# =============================================================

:10428 {
	reverse_proxy victoria-traces:10428
}