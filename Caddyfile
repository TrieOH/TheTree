# =============================================================
# 🔐 SNIPPETS
# =============================================================

(admin_auth) {
    basicauth {
        {$ADMIN_USER_NAME} {$ADMIN_PASSWORD_HASH}
    }
}

(api_routes) {
        handle /health {
                respond "ok" 200
        }

        handle_path /admin/beszel* {
            import admin_auth
            reverse_proxy beszel:8090
        }

        handle_path /identityx/* {
                reverse_proxy identity-x:8080
        }

        handle_path /informd/* {
                reverse_proxy informd:8080
        }

        handle_path /univents/* {
                reverse_proxy univents:8080
        }

        handle_path /payssage/* {
                reverse_proxy payssage:8080
        }
}

# =============================================================
# 🗄️ STORAGE (RustFS — host)
# =============================================================

api.storage.trieoh.cloud {
        log
        reverse_proxy rustfs:9000
}

console.storage.trieoh.cloud {
        log
        reverse_proxy rustfs:9001
}

# =============================================================
# 🔧 FORGEJO (Git)
# =============================================================

git.trieoh.com {
        tls /etc/caddy/certs/trieoh.com_origin.pem /etc/caddy/certs/trieoh.com_origin.key
        log
        reverse_proxy forgejo:3000
}

# =============================================================
# 🧬 UPTIME KUMA (Status Pages)
#==============================================================

status.trieoh.com {
        tls /etc/caddy/certs/trieoh.com_origin.pem /etc/caddy/certs/trieoh.com_origin.key
        log
        reverse_proxy uptime-kuma:3001
}

# =============================================================
# 🌐 API GATEWAY
# =============================================================

api.trieoh.com {
        tls /etc/caddy/certs/trieoh.com_origin.pem /etc/caddy/certs/trieoh.com_origin.key
        log
        import api_routes
}

