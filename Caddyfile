# =============================================================
# 🔐 SNIPPETS
# =============================================================

(admin_auth) {
    basicauth {
        {$ADMIN_USER_NAME} {$ADMIN_PASSWORD_HASH}
    }
}

(tls_trieoh) {
    tls /etc/caddy/certs/trieoh.com_origin.pem /etc/caddy/certs/trieoh.com_origin.key
}

(api_routes) {
    handle /health {
        respond "ok" 200
    }

    handle_path /admin/beszel* {
        import admin_auth
        reverse_proxy beszel:8090
    }

    handle_path /identityx/* {
        reverse_proxy identityx:8080
    }

    handle_path /informd/* {
        reverse_proxy informd:8080
    }

    handle_path /univents/* {
        reverse_proxy univents:8080
    }

    handle_path /payssage/* {
        reverse_proxy payssage:8080
    }
}

# =============================================================
# 🌐 API GATEWAY
# =============================================================

api.trieoh.com {
    import tls_trieoh
    log
    import api_routes
}

# =============================================================
# 🔐 IDENTITY-X
# =============================================================

api.identityx.com.br {
    reverse_proxy identityx:8080
    log
}

