# =============================================================
# 📧 MAIL (Mox — HTTP admin UI only, SMTP/IMAP are direct)
# =============================================================

http://mail.trieoh.com {
    handle /.well-known/acme-challenge/* {
        root * /var/lib/caddy/acme
    }
}

mail.trieoh.com {
    tls /etc/letsencrypt/live/mail.trieoh.com/fullchain.pem /etc/letsencrypt/live/mail.trieoh.com/privkey.pem
    handle /.well-known/acme-challenge/* {
        root * /var/lib/caddy
    }
    reverse_proxy mox:8083
}

http://mta-sts.trieoh.com {
    handle /.well-known/acme-challenge/* {
        root * /var/lib/caddy/acme
    }
}

mta-sts.trieoh.com {
    tls /etc/letsencrypt/live/mta-sts.trieoh.com/fullchain.pem /etc/letsencrypt/live/mta-sts.trieoh.com/privkey.pem
    handle /.well-known/acme-challenge/* {
        root * /var/lib/caddy
    }
    reverse_proxy mox:81
    log
}

http://autoconfig.trieoh.com {
    handle /.well-known/acme-challenge/* {
        root * /var/lib/caddy/acme
    }
}

autoconfig.trieoh.com {
    tls /etc/letsencrypt/live/mta-sts.trieoh.com/fullchain.pem /etc/letsencrypt/live/mta-sts.trieoh.com/privkey.pem
    handle /.well-known/acme-challenge/* {
        root * /var/lib/caddy
        file_server
    }
    reverse_proxy mox:81
    log
}