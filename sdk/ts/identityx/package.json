{
  "name": "@trieoh/identityx-sdk-ts",
  "version": "0.12.9",
  "type": "module",
  "description": "SDK to consume IdentityX",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./react": {
      "types": "./dist/esm/react.d.mts",
      "import": "./dist/esm/react.js",
      "require": "./dist/cjs/react.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsup",
    "typecheck": "tsc -p . --noEmit",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "https://git.trieoh.com/TrieOH/IdentityX-SDK-TS.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.4.4",
    "@storybook/react-vite": "10.4.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.25",
    "postcss": "^8.5.14",
    "storybook": "10.4.4",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@trieoh/envoy-fetch-ts": "^0.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "react-hook-form": "^7.78.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3"
  }
}