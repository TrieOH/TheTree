POSTGRES_USER=RootUserName
POSTGRES_PASSWORD=RootUserPass
POSTGRES_DB=RootUserDB

# Password is "123"
# Generate a new password with `caddy hash-password`
# this is to access the api_routes block in caddy, specifically routes behind simple auth
ADMIN_PASSWORD_HASH='$2a$14$poUC2/OI4xIsG7vv6wYHMOVb8KtJCfXdALcZ27WGjkZwHyDvl2EZ2'
ADMIN_USER_NAME=admin

# BESZEL_KEY — public key do hub
#   1. Sobe o beszel hub primeiro: just monitor
#   2. Acessa http://localhost:8090 e cria a conta admin
#   3. Clica em "Add System"
#   4. Em "Host/IP" coloca o socket: /beszel_socket/beszel.sock
#   5. Copia o valor de "Public Key" (começa com ssh-ed25519 ...)
#   6. Copia o "Token"
#   7. Clica em "Add System" pra confirmar
#   8. Preenche BESZEL_KEY e BESZEL_TOKEN abaixo e reinicia o stack
BESZEL_PUBLIC_KEY=
BESZEL_TOKEN=

# Plain text
GRAFANA_ADMIN_PASSWORD=
