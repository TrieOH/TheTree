{
  "title": "TrieOH — Infra",
  "uid": "trieoh-infra",
  "tags": ["trieoh", "infra"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      { "name": "DS_VM", "type": "datasource", "pluginId": "victoriametrics-metrics-datasource", "hide": 2 },
      { "name": "DS_VL", "type": "datasource", "pluginId": "victoriametrics-logs-datasource", "hide": 2 }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "title": "Services Up",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "count(up{job=~\"identityx|informd|payssage|univents\"} == 1)", "legendFormat": "up" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 2 }, { "color": "green", "value": 4 }] } } },
      "options": { "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat", "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "title": "Scrape Targets Up",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "count(up == 1)", "legendFormat": "up" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "options": { "colorMode": "background" }
    },
    {
      "id": 3, "type": "stat", "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "title": "Scrape Duration (max)",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "max(scrape_duration_seconds)", "legendFormat": "ms" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } } },
      "options": { "colorMode": "background" }
    },

    {
      "id": 10, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "title": "Service Uptime",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "up{job=~\"identityx|informd|payssage|univents\"}", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 11, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "title": "Scrape Duration per Job",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "scrape_duration_seconds", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 20, "type": "timeseries", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "title": "Go Goroutines per Service",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "go_goroutines{job=~\"identityx|informd|payssage|univents\"}", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 21, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "title": "Go Heap Alloc per Service",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "go_memstats_heap_alloc_bytes{job=~\"identityx|informd|payssage|univents\"}", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 22, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "title": "GC Pause Duration",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "${DS_VM}" },
      "targets": [{ "expr": "rate(go_gc_duration_seconds_sum{job=~\"identityx|informd|payssage|univents\"}[5m])", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 30, "type": "logs", "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "title": "All Service Errors",
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VL}" },
      "targets": [{ "expr": "{service=~\"identityx|informd|payssage|univents\", level=\"error\"}", "legendFormat": "" }],
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ]
}